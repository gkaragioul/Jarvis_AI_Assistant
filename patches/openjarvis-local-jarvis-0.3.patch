+function estimateWavDurationMs(buffer: ArrayBuffer): number {
+  const fallbackMs = 2500;
+  if (buffer.byteLength < 44) return fallbackMs;
+
+  const view = new DataView(buffer);
+  const riff = String.fromCharCode(...new Uint8Array(buffer, 0, 4));
+  const wave = String.fromCharCode(...new Uint8Array(buffer, 8, 4));
+  if (riff !== 'RIFF' || wave !== 'WAVE') return fallbackMs;
+
+  let byteRate = 0;
+  let dataSize = 0;
+  let offset = 12;
+  while (offset + 8 <= buffer.byteLength) {
+    const id = String.fromCharCode(...new Uint8Array(buffer, offset, 4));
+    const size = view.getUint32(offset + 4, true);
+    if (id === 'fmt ' && offset + 16 <= buffer.byteLength) {
+      byteRate = view.getUint32(offset + 12, true);
+    } else if (id === 'data') {
+      dataSize = size;
+      break;
+    }
+    offset += 8 + size + (size % 2);
+  }
+
+  if (!byteRate || !dataSize) return fallbackMs;
+  return Math.max(600, Math.round((dataSize / byteRate) * 1000));
+}
