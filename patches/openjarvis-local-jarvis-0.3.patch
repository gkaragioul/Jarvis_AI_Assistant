+        r"\s*How\s+(?:can|may)\s+I\s+(?:assist|help)\s+you[^.?!]*(?:[.?!]|$)",
+        r"\s*(?:Let me know|Tell me)\s+[^.?!]*(?:assist|help)[^.?!]*(?:[.?!]|$)",
