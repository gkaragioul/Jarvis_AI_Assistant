+/// Record a short microphone sample through macOS AVFoundation via ffmpeg.
+/// This is the desktop fallback for WKWebView builds that do not expose
+/// navigator.mediaDevices on the tauri://localhost origin.
+#[tauri::command]
+async fn record_mic_sample(duration_ms: u64) -> Result<Vec<u8>, String> {
+    let ffmpeg_bin = resolve_bin("ffmpeg");
+    if ffmpeg_bin == "ffmpeg" || !std::path::Path::new(&ffmpeg_bin).exists() {
+        return Err(
+            "Could not find ffmpeg for native microphone recording. Install it with: brew install ffmpeg"
+                .into(),
+        );
+    }
+
+    let duration_secs = (duration_ms as f64 / 1000.0).clamp(0.5, 10.0);
+    let stamp = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .map(|d| d.as_millis())
+        .unwrap_or_default();
+    let path = std::env::temp_dir().join(format!(
+        "openjarvis-mic-{}-{}.wav",
+        std::process::id(),
+        stamp
+    ));
+    let path_str = path.to_string_lossy().to_string();
+    let duration_arg = format!("{duration_secs:.2}");
+
+    let output = tokio::process::Command::new(&ffmpeg_bin)
+        .args([
+            "-hide_banner",
+            "-loglevel",
+            "error",
+            "-y",
+            "-f",
+            "avfoundation",
+            "-i",
+            ":0",
+            "-t",
+            &duration_arg,
+            "-ar",
+            "16000",
+            "-ac",
+            "1",
+            "-c:a",
+            "pcm_s16le",
+            &path_str,
+        ])
+        .output()
+        .await
+        .map_err(|e| format!("Failed to start native microphone recorder: {}", e))?;
+
+    if !output.status.success() {
+        let stderr = String::from_utf8_lossy(&output.stderr).trim().to_string();
+        let _ = std::fs::remove_file(&path);
+        let detail = if stderr.is_empty() {
+            "ffmpeg could not read the microphone.".to_string()
+        } else {
+            stderr
+        };
+        return Err(format!(
+            "Native microphone recording failed: {detail}. Check macOS microphone permission for Jarvis."
+        ));
+    }
+
+    let bytes = std::fs::read(&path)
+        .map_err(|e| format!("Failed to read recorded microphone sample: {}", e))?;
+    let _ = std::fs::remove_file(&path);
+    if bytes.is_empty() {
+        return Err("Native microphone recording returned an empty audio file.".into());
+    }
+    Ok(bytes)
+}
