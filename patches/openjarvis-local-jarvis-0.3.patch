+@speech_router.post("/synthesize")
+async def synthesize_speech(req: SpeechSynthesizeRequest, request: Request):
+    """Synthesize assistant text on the PC-side Jarvis voice service."""
+    text = req.text.strip()
+    if not text:
+        raise HTTPException(status_code=400, detail="Missing text")
+
+    config = getattr(request.app.state, "config", None)
+    default_voice_id = getattr(getattr(config, "digest", None), "voice_id", "") or "jarvis_online_derek"
+    selected_voice_id = req.voice_id or default_voice_id
+    if selected_voice_id != "jarvis_online_derek":
+        raise HTTPException(
+            status_code=400,
+            detail="Jarvis voice is locked to jarvis_online_derek",
+        )
+    requested_fx = req.fx or "none"
+
+    try:
+        import httpx
+
+        async with httpx.AsyncClient(timeout=120.0) as client:
+            remote = await client.post(
+                REMOTE_TTS_URL,
+                json={
+                    "text": text,
+                    "voice_id": selected_voice_id,
+                    "speed": req.speed or 1.0,
+                    "fx": requested_fx,
+                    "mode": req.mode or "fast",
+                },
+            )
+        if remote.status_code >= 400:
+            raise HTTPException(
+                status_code=remote.status_code,
+                detail=f"Remote Jarvis voice failed: {remote.text[:500]}",
+            )
+        return Response(
+            content=remote.content,
+            media_type=remote.headers.get("content-type", "audio/wav"),
+            headers={
+                "X-Jarvis-Voice": remote.headers.get("X-Jarvis-Voice", selected_voice_id),
+                "X-Jarvis-TTS": remote.headers.get("X-Jarvis-TTS", "fast-derek-cache"),
+                "X-Jarvis-TTS-Device": remote.headers.get("X-Jarvis-TTS-Device", "pc"),
+                "X-Jarvis-TTS-Cache": remote.headers.get("X-Jarvis-TTS-Cache", "unknown"),
+                "X-Jarvis-TTS-Ms": remote.headers.get("X-Jarvis-TTS-Ms", ""),
+                "X-Jarvis-TTS-Host": "100.117.254.71",
+            },
+        )
+    except HTTPException:
+        raise
+    except Exception as exc:
+        logger.exception("Remote speech synthesis failed")
+        raise HTTPException(status_code=502, detail=f"Remote Jarvis voice unavailable: {exc}") from exc
+
+    backend_key = getattr(getattr(config, "digest", None), "tts_backend", "kokoro")
+    voice_id = req.voice_id or getattr(getattr(config, "digest", None), "voice_id", "")
+    speed = req.speed or getattr(getattr(config, "digest", None), "voice_speed", 1.0)
+    voice_id = voice_id or "jarvis_online_derek"
+
+    try:
+        import openjarvis.speech  # noqa: F401 - registers TTS backends
+        from openjarvis.core.registry import TTSRegistry
+
+        cache_key = "_tts_backend"
+        backend = getattr(request.app.state, cache_key, None)
+        if backend is None or getattr(backend, "backend_id", "") != backend_key:
+            backend = TTSRegistry.create(backend_key)
+            setattr(request.app.state, cache_key, backend)
+
+        lock = getattr(request.app.state, "_tts_lock", None)
+        if lock is None:
+            lock = asyncio.Lock()
+            setattr(request.app.state, "_tts_lock", lock)
+        if lock.locked():
+            raise HTTPException(status_code=429, detail="Jarvis voice is still preparing the previous reply")
+
+        async with lock:
+            result = await asyncio.to_thread(
+                backend.synthesize,
+                text,
+                voice_id=voice_id,
+                speed=speed,
+                output_format="wav",
+            )
+        audio = result.audio
+
+        fx = req.fx.lower()
+        if fx in {"jarvis", "normal", "strong", "jarvis_strong", "presence", "weight"}:
+            from openjarvis.speech.effects import apply_jarvis_fx_to_wav
+
+            strength = (
+                "presence"
+                if fx in {"presence", "weight"}
+                else "strong"
+                if fx in {"strong", "jarvis_strong"}
+                else "normal"
+            )
+            audio = await asyncio.to_thread(apply_jarvis_fx_to_wav, audio, strength=strength)
+        elif fx not in {"", "none", "off"}:
+            raise HTTPException(status_code=400, detail="Unknown voice FX")
+
+        return Response(
+            content=audio,
+            media_type="audio/wav",
+            headers={
+                "X-Jarvis-Voice": voice_id,
+                "X-Jarvis-TTS": getattr(backend, "backend_id", backend_key),
+            },
+        )
+    except HTTPException:
+        raise
+    except Exception as exc:
+        logger.exception("Speech synthesis failed")
+        raise HTTPException(status_code=500, detail=str(exc)) from exc
+
