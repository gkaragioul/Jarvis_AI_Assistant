+
+  if (detectedLanguage && detectedLanguage !== 'en' && (confidence ?? 1) > 0.45) {
+    return false;
+  }
+
+  const letters = Array.from(trimmed).filter((char) => /\p{L}/u.test(char));
+  if (letters.length === 0) return true;
+  const latinLetters = letters.filter((char) => /[A-Za-z]/.test(char)).length;
+  if (latinLetters / letters.length < 0.85) return false;
+
+  const nonEnglishSignals =
+    /\b(el|la|los|las|de|que|una|und|der|die|das|ich|nicht|est|avec|pour|και|είναι|στο|την)\b/i;
