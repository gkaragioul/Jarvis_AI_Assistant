+}
+
+/// Play generated speech through macOS directly. This avoids WebView
+/// autoplay blocking when Jarvis is responding to hands-free voice input.
+#[tauri::command]
+async fn play_audio_data(audio_data: Vec<u8>, extension: Option<String>) -> Result<(), String> {
+    stop_audio_playback_internal().await;
+
+    let ext = extension
+        .unwrap_or_else(|| "wav".into())
+        .trim_start_matches('.')
+        .chars()
+        .filter(|c| c.is_ascii_alphanumeric())
+        .collect::<String>();
+    let ext = if ext.is_empty() { "wav".to_string() } else { ext };
+    let stamp = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .map(|d| d.as_millis())
+        .unwrap_or_default();
+    let path = std::env::temp_dir().join(format!(
+        "openjarvis-voice-{}-{}.{}",
+        std::process::id(),
+        stamp,
+        ext
+    ));
+
+    tokio::fs::write(&path, audio_data)
+        .await
+        .map_err(|e| format!("Failed to write speech audio: {}", e))?;
+
+    let afplay_bin = resolve_bin("afplay");
+    if afplay_bin == "afplay" || !std::path::Path::new(&afplay_bin).exists() {
+        let _ = tokio::fs::remove_file(&path).await;
+        return Err("Could not find afplay for native audio playback.".into());
+    }
+
+    let mut child = tokio::process::Command::new(&afplay_bin)
+        .arg(&path)
+        .spawn()
+        .map_err(|e| format!("Failed to play speech audio: {}", e))?;
+    let pid = child.id().unwrap_or_default();
+    if pid != 0 {
+        audio_playback_state().lock().await.push(AudioPlayback {
+            pid,
+            path: path.clone(),
+            remove_file: true,
+        });
+    }
+    tauri::async_runtime::spawn(async move {
+        let _ = child.wait().await;
+        if pid != 0 {
+            let mut active = audio_playback_state().lock().await;
+            active.retain(|entry| entry.pid != pid);
+        }
+        let _ = tokio::fs::remove_file(&path).await;
+    });
+
+    Ok(())
+}
+
+/// Play an existing local audio file through macOS directly.
+#[tauri::command]
+async fn play_audio_file(path: String) -> Result<(), String> {
+    stop_audio_playback_internal().await;
+
+    let path = std::path::PathBuf::from(path);
+    if !path.exists() {
+        return Err(format!("Audio file not found: {}", path.display()));
+    }
+
+    let afplay_bin = resolve_bin("afplay");
+    if afplay_bin == "afplay" || !std::path::Path::new(&afplay_bin).exists() {
+        return Err("Could not find afplay for native audio playback.".into());
+    }
+
+    let mut child = tokio::process::Command::new(&afplay_bin)
+        .arg(path)
+        .spawn()
+        .map_err(|e| format!("Failed to play speech audio: {}", e))?;
+    let pid = child.id().unwrap_or_default();
+    if pid != 0 {
+        audio_playback_state().lock().await.push(AudioPlayback {
+            pid,
+            path: std::path::PathBuf::new(),
+            remove_file: false,
+        });
+    }
+    tauri::async_runtime::spawn(async move {
+        let _ = child.wait().await;
+        if pid != 0 {
+            let mut active = audio_playback_state().lock().await;
+            active.retain(|entry| entry.pid != pid);
+        }
+    });
+
+    Ok(())
+}
+
+async fn stop_audio_playback_internal() {
+    let entries = {
+        let mut active = audio_playback_state().lock().await;
+        active.drain(..).collect::<Vec<_>>()
+    };
+
+    for entry in entries {
+        if entry.pid != 0 {
+            let _ = tokio::process::Command::new("/bin/kill")
+                .args(["-TERM", &entry.pid.to_string()])
+                .status()
+                .await;
+        }
+        if entry.remove_file && !entry.path.as_os_str().is_empty() {
+            let _ = tokio::fs::remove_file(entry.path).await;
+        }
+    }
+}
+
+#[tauri::command]
+async fn stop_audio_playback() -> Result<(), String> {
+    stop_audio_playback_internal().await;
+    Ok(())
+}
