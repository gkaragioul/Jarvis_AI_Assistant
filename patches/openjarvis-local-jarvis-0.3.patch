+#[tauri::command]
+async fn start_mic_recording() -> Result<(), String> {
+    let mut active = mic_recording_state().lock().await;
+    if active.is_some() {
+        return Ok(());
+    }
+
+    let ffmpeg_bin = resolve_bin("ffmpeg");
+    if ffmpeg_bin == "ffmpeg" || !std::path::Path::new(&ffmpeg_bin).exists() {
+        return Err(
+            "Could not find ffmpeg for native microphone recording. Install it with: brew install ffmpeg"
+                .into(),
+        );
+    }
+
+    let stamp = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .map(|d| d.as_millis())
+        .unwrap_or_default();
+    let path = std::env::temp_dir().join(format!(
+        "openjarvis-ptt-{}-{}.wav",
+        std::process::id(),
+        stamp
+    ));
+    let path_str = path.to_string_lossy().to_string();
+
+    let child = tokio::process::Command::new(&ffmpeg_bin)
+        .args([
+            "-hide_banner",
+            "-loglevel",
+            "error",
+            "-y",
+            "-f",
+            "avfoundation",
+            "-i",
+            ":0",
+            "-t",
+            "30",
+            "-ar",
+            "16000",
+            "-ac",
+            "1",
+            "-c:a",
+            "pcm_s16le",
+            &path_str,
+        ])
+        .stdin(std::process::Stdio::piped())
+        .stdout(std::process::Stdio::null())
+        .stderr(std::process::Stdio::piped())
+        .spawn()
+        .map_err(|e| format!("Failed to start native microphone recorder: {}", e))?;
+
+    *active = Some(MicRecording { child, path });
+    Ok(())
+}
+
+#[tauri::command]
+async fn stop_mic_recording() -> Result<Vec<u8>, String> {
+    let recording = {
+        let mut active = mic_recording_state().lock().await;
+        active.take()
+    };
+    let mut recording = recording.ok_or_else(|| "Native microphone was not recording.".to_string())?;
+
+    if let Some(mut stdin) = recording.child.stdin.take() {
+        let _ = stdin.write_all(b"q\n").await;
+        let _ = stdin.flush().await;
+    }
+
+    let output = match tokio::time::timeout(Duration::from_secs(3), recording.child.wait_with_output()).await {
+        Ok(result) => result.map_err(|e| format!("Failed to stop native microphone recorder: {}", e))?,
+        Err(_) => {
+            let _ = std::fs::remove_file(&recording.path);
+            return Err("Native microphone recorder did not stop cleanly.".into());
+        }
+    };
+
+    let bytes = std::fs::read(&recording.path)
+        .map_err(|e| format!("Failed to read recorded microphone sample: {}", e))?;
+    let _ = std::fs::remove_file(&recording.path);
+
+    if bytes.is_empty() {
+        let stderr = String::from_utf8_lossy(&output.stderr).trim().to_string();
+        let detail = if stderr.is_empty() {
+            "No audio was recorded. Hold Control+Option+J while speaking.".to_string()
+        } else {
+            stderr
+        };
+        return Err(format!("Native microphone recording failed: {detail}"));
+    }
+
