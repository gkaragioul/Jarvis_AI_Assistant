+@speech_router.post("/speaker/verify")
+async def speaker_verify(request: Request):
+    """Verify that an uploaded utterance matches the enrolled Sir profile."""
+    form = await request.form()
+    audio_file = form.get("file")
+    if audio_file is None:
+        raise HTTPException(status_code=400, detail="Missing 'file' field")
+
+    audio_bytes = await audio_file.read()
+    filename = getattr(audio_file, "filename", "audio.wav")
+
+    try:
+        from openjarvis.speech.speaker_verification import SpeakerVerifier
+
+        return SpeakerVerifier().verify(audio_bytes, filename)
+    except Exception as exc:
+        logger.exception("Speaker verification failed")
+        raise HTTPException(status_code=500, detail=str(exc)) from exc
